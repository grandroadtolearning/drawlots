<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="theme-color" content="#0a0a14">
<title>賽棋日｜即時戰況</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  html, body {
    background: radial-gradient(ellipse at top, #1a1a2e 0%, #0a0a14 100%);
    color: #f3f4f6;
    font-family: -apple-system, "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }
  body { padding: 20px 16px 80px; max-width: 480px; margin: 0 auto; }

  /* Header */
  .header { text-align: center; margin-bottom: 20px; }
  .event-title { font-size: 22px; font-weight: 800; letter-spacing: 0.05em; }
  .event-date { font-size: 13px; color: #9ca3af; margin-top: 4px; }

  /* Card */
  .card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px;
    padding: 20px;
    margin-bottom: 14px;
    backdrop-filter: blur(10px);
  }
  .card-label { font-size: 12px; color: #9ca3af; letter-spacing: 0.15em; margin-bottom: 8px; }

  /* Form */
  .form-card {
    background: linear-gradient(135deg, rgba(99,102,241,0.15) 0%, rgba(139,92,246,0.08) 100%);
    border: 1px solid rgba(139,92,246,0.25);
    padding: 24px 20px;
  }
  .form-title { font-size: 20px; font-weight: 800; text-align: center; margin-bottom: 6px; }
  .form-sub { font-size: 13px; color: #c4b5fd; text-align: center; margin-bottom: 20px; }
  .field-label { font-size: 13px; font-weight: 600; color: #d1d5db; margin: 16px 0 8px; display: block; }
  .field-label .req { color: #fbbf24; margin-left: 4px; }
  .name-input {
    width: 100%; padding: 14px 16px; font-size: 17px;
    background: rgba(0,0,0,0.3); border: 1.5px solid rgba(255,255,255,0.12); border-radius: 12px;
    color: #fff; -webkit-appearance: none; appearance: none;
  }
  .name-input:focus { outline: none; border-color: #fbbf24; }
  .name-input::placeholder { color: #6b7280; }
  .track-choices { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  .track-btn {
    background: rgba(255,255,255,0.04); border: 1.5px solid rgba(255,255,255,0.12);
    border-radius: 14px; padding: 14px 6px; text-align: center; cursor: pointer; user-select: none;
  }
  .track-btn .emoji { font-size: 28px; line-height: 1; }
  .track-btn .name { font-size: 14px; font-weight: 700; margin-top: 6px; }
  .track-btn .note { font-size: 10px; color: #9ca3af; margin-top: 2px; letter-spacing: 0.05em; }
  .track-btn.selected { background: rgba(251,191,36,0.15); border-color: #fbbf24; }
  .track-btn.selected .note { color: #fbbf24; }
  .submit-btn {
    width: 100%; margin-top: 20px; padding: 16px; font-size: 17px; font-weight: 800;
    background: linear-gradient(90deg, #fbbf24, #f59e0b); color: #1a1a2e;
    border: none; border-radius: 14px; cursor: pointer; letter-spacing: 0.05em;
  }
  .submit-btn:active { transform: scale(0.98); }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .form-error {
    background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5;
    padding: 10px 14px; border-radius: 10px; font-size: 13px; margin-top: 14px; display: none;
  }
  .form-error.show { display: block; }

  /* Personal slot */
  .slot-card {
    background: linear-gradient(135deg, rgba(251,191,36,0.15) 0%, rgba(251,146,60,0.08) 100%);
    border: 1px solid rgba(251,191,36,0.3);
    text-align: center; padding: 24px 20px;
  }
  .track-badge {
    display: inline-block; font-size: 11px; letter-spacing: 0.15em; color: #fbbf24;
    background: rgba(251,191,36,0.12); border: 1px solid rgba(251,191,36,0.3);
    padding: 3px 10px; border-radius: 999px; margin-bottom: 10px; font-weight: 700;
  }
  .slot-name { font-size: 15px; color: #fbbf24; margin-bottom: 4px; font-weight: 600; }
  .slot-number {
    font-size: 64px; font-weight: 900; line-height: 1;
    background: linear-gradient(180deg, #fde68a 0%, #fbbf24 100%);
    -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    margin: 4px 0 10px;
  }
  .slot-status { font-size: 15px; color: #f3f4f6; font-weight: 500; }
  .slot-status .num { font-weight: 800; color: #fbbf24; font-size: 18px; }
  .slot-status.urgent { color: #4ade80; font-weight: 700; animation: pulse 1.5s ease-in-out infinite; }
  .slot-status.playing { color: #60a5fa; font-weight: 700; }
  @keyframes pulse { 50% { opacity: 0.6; } }
  .slot-hint { font-size: 13px; color: #9ca3af; margin-top: 10px; }
  /* 個人積分區 */
  .slot-stats {
    display: flex; justify-content: center; gap: 24px; margin-top: 14px;
    padding-top: 14px; border-top: 1px solid rgba(251,191,36,0.2);
  }
  .stat { text-align: center; }
  .stat-label { font-size: 11px; color: #9ca3af; letter-spacing: 0.1em; }
  .stat-value { font-size: 22px; font-weight: 800; color: #fbbf24; line-height: 1.1; margin-top: 2px; }
  .stat-value.muted { color: #6b7280; }
  .slot-actions { margin-top: 14px; }
  .text-btn {
    font-size: 12px; color: #9ca3af; background: none; border: none;
    text-decoration: underline; cursor: pointer; padding: 4px 8px;
  }

  /* Prize */
  .prize {
    background: linear-gradient(90deg, #fbbf24 0%, #f59e0b 100%);
    color: #1a1a2e; text-align: center; padding: 14px;
    border-radius: 14px; font-weight: 800; font-size: 15px;
    letter-spacing: 0.03em; margin-bottom: 16px;
    box-shadow: 0 4px 20px rgba(251,191,36,0.3);
  }

  /* Per-track section */
  .track-section { margin-bottom: 14px; }
  .track-header {
    display: flex; align-items: center; gap: 10px; padding: 14px 18px;
    background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
    border-radius: 18px 18px 0 0; border-bottom: none;
  }
  .track-header .te { font-size: 22px; line-height: 1; }
  .track-header .tname { font-size: 16px; font-weight: 800; flex: 1; }
  .track-header .waiting {
    font-size: 11px; color: #9ca3af; padding: 4px 10px;
    background: rgba(255,255,255,0.04); border-radius: 999px;
  }
  .track-header .waiting .n { color: #fbbf24; font-weight: 800; }
  .king-line {
    display: flex; align-items: center; gap: 8px; padding: 10px 18px;
    background: linear-gradient(90deg, rgba(251,191,36,0.12), rgba(251,191,36,0.04));
    border-left: 1px solid rgba(255,255,255,0.08);
    border-right: 1px solid rgba(255,255,255,0.08);
    font-size: 13px;
  }
  .king-line.empty {
    background: rgba(255,255,255,0.02);
    color: #6b7280;
    font-style: italic;
  }
  .king-line .crown { font-size: 16px; }
  .king-line .label { color: #9ca3af; font-size: 11px; letter-spacing: 0.1em; }
  .king-line .name { font-weight: 800; color: #fbbf24; flex: 1; }

  .track-board {
    background: rgba(255,255,255,0.03); padding: 8px 14px 14px;
    border: 1px solid rgba(255,255,255,0.08); border-top: none;
    border-radius: 0 0 18px 18px;
  }
  .lb-row {
    display: grid; grid-template-columns: 36px 1fr auto; gap: 10px;
    align-items: center; padding: 10px 4px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .lb-row:last-child { border-bottom: none; }
  .lb-row.me { background: rgba(251,191,36,0.08); margin: 0 -8px; padding: 10px 12px; border-radius: 8px; }
  .rank {
    font-size: 18px; font-weight: 800; color: #6b7280; text-align: center;
  }
  .lb-row.r1 .rank { color: #fbbf24; font-size: 22px; }
  .lb-row.r2 .rank { color: #d1d5db; }
  .lb-row.r3 .rank { color: #fb923c; }
  .lb-name { font-size: 15px; font-weight: 600; }
  .lb-points { font-size: 13px; color: #fbbf24; font-weight: 700; font-variant-numeric: tabular-nums; }
  .lb-points .lbl { color: #9ca3af; font-weight: 400; font-size: 11px; margin-left: 2px; }
  .lb-empty { padding: 14px 4px; color: #6b7280; font-size: 13px; text-align: center; font-style: italic; }

  /* Hero (when no ?id) */
  .hero {
    text-align: center; padding: 28px 20px;
    background: linear-gradient(135deg, rgba(99,102,241,0.15) 0%, rgba(139,92,246,0.08) 100%);
    border: 1px solid rgba(139,92,246,0.25);
    border-radius: 18px; margin-bottom: 16px;
  }

  /* Footer */
  .footer {
    position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
    background: rgba(26,26,46,0.9); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1); border-radius: 999px;
    padding: 8px 16px; font-size: 12px; color: #9ca3af;
    display: flex; align-items: center; gap: 8px; cursor: pointer;
  }
  .footer .dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; animation: pulse 2s infinite; }

  .setup-warning {
    background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.4);
    padding: 16px; border-radius: 12px; color: #fca5a5;
    font-size: 13px; line-height: 1.6; margin-bottom: 16px;
  }
  .setup-warning strong { color: #fbbf24; }
  .setup-warning code { background: rgba(0,0,0,0.4); padding: 2px 6px; border-radius: 4px; font-family: monospace; font-size: 12px; color: #fbbf24; }
</style>
</head>
<body>

  <div class="header">
    <div class="event-title">🎲 賽棋日</div>
    <div class="event-date" id="ev-date">5/25 (一)</div>
  </div>

  <div id="setup-area"></div>
  <div id="slot-area"></div>

  <div class="prize" id="prize">當日各賽道 #1 → 明天請星巴克 ☕</div>

  <!-- 三條賽道 sections（動態 render） -->
  <div id="tracks-area"></div>

  <div class="footer" onclick="refresh()">
    <span class="dot"></span>
    <span>點我更新 · <span id="updated">--:--</span></span>
  </div>

<script>
// ===========================================================
// 🛠 Apps Script Web App URL（跟 admin.html 同一條）
// ===========================================================
const APPS_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbxr8HQVnQQZA0Hrqpn_m08FAMV6B04jl5D3yELVJDvWbQ_iRxzcbAJfT3f8JEx2qgCs/exec";

const EVENT_DATE = "5/25 (一)";
const PRIZE_TEXT = "當日各賽道 #1 → 明天請星巴克 ☕";
const TRACKS = [
  { name: "象棋",   emoji: "♟️", note: "2 人對戰" },
  { name: "拉密",   emoji: "🀄", note: "4 人開桌" },
  { name: "五子棋", emoji: "⚫", note: "2 人對戰" },
];

const $ = id => document.getElementById(id);
const STORAGE_KEY = "chess_day_my_id";
let cachedData = null;
let myId = null;
let selectedTrack = null;

function init() {
  $("ev-date").textContent = EVENT_DATE;
  $("prize").textContent = PRIZE_TEXT;
  const urlId = new URLSearchParams(location.search).get("id");
  myId = urlId || localStorage.getItem(STORAGE_KEY) || null;

  if (!APPS_SCRIPT_URL) {
    showSetupWarning();
    renderTracks(null);
    return;
  }
  renderSlotArea();
  refresh();
  setInterval(refresh, 20000);
}

function showSetupWarning() {
  $("setup-area").innerHTML = `
    <div class="setup-warning">
      <strong>⚠️ 還沒設定後台</strong><br>
      把 Apps Script Web App URL 貼到 <code>index.html</code> 裡的 <code>APPS_SCRIPT_URL</code>。
    </div>`;
}

async function refresh() {
  if (!APPS_SCRIPT_URL) return;
  try {
    const res = await fetch(APPS_SCRIPT_URL + "?t=" + Date.now());
    const data = await res.json();
    if (!data.ok) throw new Error(data.error);
    cachedData = data;
    renderAll();
    const now = new Date();
    $("updated").textContent = String(now.getHours()).padStart(2,"0") + ":" + String(now.getMinutes()).padStart(2,"0");
  } catch (err) { console.error(err); }
}

function renderAll() { renderSlotArea(); renderTracks(cachedData); }

// ===== 個人 / 表單 =====

function renderSlotArea() {
  const slotArea = $("slot-area");
  if (myId && cachedData && cachedData.participants[myId]) {
    slotArea.innerHTML = personalCard(cachedData.participants[myId]);
    return;
  }
  if (myId && !cachedData) {
    slotArea.innerHTML = `<div class="card form-card" style="text-align:center;"><div class="form-sub">讀取你的狀態中...</div></div>`;
    return;
  }
  if (myId && cachedData && !cachedData.participants[myId]) {
    localStorage.removeItem(STORAGE_KEY); myId = null;
  }
  slotArea.innerHTML = registerForm();
}

function personalCard(p) {
  const trackBadge = p.track ? `<div class="track-badge">${p.track}</div>` : "";
  let statusHtml = "";

  if (p.status === "playing") {
    statusHtml = `<div class="slot-status playing">🎮 比賽進行中</div>`;
  } else if (p.status === "done") {
    statusHtml = `<div class="slot-status">已完賽 · 想再戰？找賽務或回 LINE「再來」</div>`;
  } else if (p.track === "拉密") {
    if (p.peopleNeeded === 0)      statusHtml = `<div class="slot-status urgent">🔔 4 人到齊！快回來開桌</div>`;
    else if (p.peopleNeeded === 1) statusHtml = `<div class="slot-status urgent">⚡ 再 <span class="num">1</span> 人就開始！</div>`;
    else                            statusHtml = `<div class="slot-status">再 <span class="num">${p.peopleNeeded}</span> 人就湊滿開桌</div>`;
  } else {
    if (p.peopleAhead === 0)       statusHtml = `<div class="slot-status urgent">🔔 輪到你了！快回來</div>`;
    else if (p.peopleAhead === 1)  statusHtml = `<div class="slot-status urgent">⚡ 下一場就是你！</div>`;
    else if (p.peopleAhead <= 2)   statusHtml = `<div class="slot-status urgent">⚠️ 前面剩 <span class="num">${p.peopleAhead}</span> 人</div>`;
    else                            statusHtml = `<div class="slot-status">前面還有 <span class="num">${p.peopleAhead}</span> 人</div>`;
  }

  const points = p.points || 0;
  const trackRank = p.trackRank;
  const rankDisplay = trackRank ? `#${trackRank}` : "—";

  return `
    <div class="card slot-card">
      ${trackBadge}
      <div class="slot-name">${escapeHtml(p.name)}</div>
      <div class="slot-number">#${String(myId).padStart(2, "0")}</div>
      ${statusHtml}
      <div class="slot-hint">可以先去逛，輪到了 LINE 會通知你</div>
      <div class="slot-stats">
        <div class="stat">
          <div class="stat-label">我的積分</div>
          <div class="stat-value ${points === 0 ? 'muted' : ''}">${points}</div>
        </div>
        <div class="stat">
          <div class="stat-label">${p.track}排名</div>
          <div class="stat-value ${!trackRank ? 'muted' : ''}">${rankDisplay}</div>
        </div>
      </div>
      <div class="slot-actions">
        <button class="text-btn" onclick="resetMe()">換一個遊戲</button>
      </div>
    </div>
  `;
}

function registerForm() {
  return `
    <div class="card form-card">
      <div class="form-title">想加入今日戰局？</div>
      <div class="form-sub">填一下，30 秒搞定</div>
      <label class="field-label">你的暱稱 <span class="req">*</span></label>
      <input id="f-name" class="name-input" type="text" maxlength="12" placeholder="想被叫什麼？最多 12 字" autocomplete="off">
      <label class="field-label">想玩什麼 <span class="req">*</span></label>
      <div class="track-choices">
        ${TRACKS.map(t => `
          <div class="track-btn" data-track="${t.name}" onclick="selectTrack('${t.name}')">
            <div class="emoji">${t.emoji}</div>
            <div class="name">${t.name}</div>
            <div class="note">${t.note}</div>
          </div>
        `).join("")}
      </div>
      <div id="f-error" class="form-error"></div>
      <button id="f-submit" class="submit-btn" onclick="submitForm()">🎲 加入戰局</button>
    </div>
  `;
}

function selectTrack(name) {
  selectedTrack = name;
  document.querySelectorAll(".track-btn").forEach(el => {
    el.classList.toggle("selected", el.dataset.track === name);
  });
}

async function submitForm() {
  const name = $("f-name").value.trim();
  const errorEl = $("f-error");
  errorEl.classList.remove("show");
  if (!name) return showError("請輸入暱稱");
  if (!selectedTrack) return showError("請選一個遊戲");

  const btn = $("f-submit");
  btn.disabled = true; btn.textContent = "報名中...";
  try {
    const res = await fetch(APPS_SCRIPT_URL, {
      method: "POST",
      body: JSON.stringify({ action: "register", name: name, track: selectedTrack })
    });
    const data = await res.json();
    if (!data.ok) throw new Error(data.error || "報名失敗");
    myId = String(data.id);
    localStorage.setItem(STORAGE_KEY, myId);
    await refresh();
  } catch (err) {
    showError("報名失敗：" + err.message);
    btn.disabled = false; btn.textContent = "🎲 加入戰局";
  }
}

function showError(msg) { const e = $("f-error"); e.textContent = msg; e.classList.add("show"); }

function resetMe() {
  if (!confirm("確定要換一個遊戲嗎？目前的號碼會作廢。")) return;
  localStorage.removeItem(STORAGE_KEY); myId = null;
  renderSlotArea();
}

// ===== 三條賽道 sections =====

function renderTracks(data) {
  $("tracks-area").innerHTML = TRACKS.map(t => {
    const waiting = data && data.tracks ? (data.tracks[t.name] || 0) : "?";
    const king = data && data.kings ? data.kings[t.name] : null;
    const top3 = (data && data.top3ByTrack && data.top3ByTrack[t.name]) || [];
    const myName = (myId && data && data.participants && data.participants[myId]) ? data.participants[myId].name : null;

    const kingLine = king
      ? `<div class="king-line"><span class="crown">👑</span><span class="label">現任王</span><span class="name">${escapeHtml(king)}</span></div>`
      : `<div class="king-line empty"><span class="crown">👑</span><span class="label">王位 ─</span><span class="name" style="color:#6b7280;font-weight:400;">尚無人登基</span></div>`;

    let lbHtml;
    if (top3.length === 0) {
      lbHtml = `<div class="lb-empty">還沒有戰績，第一個贏的就是 #1 🏆</div>`;
    } else {
      lbHtml = top3.map((p, i) => {
        const rank = i + 1;
        const isMe = myName && p.name === myName;
        return `
          <div class="lb-row r${rank} ${isMe ? 'me' : ''}">
            <div class="rank">${rank}</div>
            <div class="lb-name">${escapeHtml(p.name)}${isMe ? ' · 你' : ''}</div>
            <div class="lb-points">${p.points}<span class="lbl">分</span></div>
          </div>
        `;
      }).join("");
    }

    return `
      <div class="track-section">
        <div class="track-header">
          <span class="te">${t.emoji}</span>
          <span class="tname">${t.name}</span>
          <span class="waiting">等候 <span class="n">${waiting}</span></span>
        </div>
        ${kingLine}
        <div class="track-board">${lbHtml}</div>
      </div>
    `;
  }).join("");
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
}

init();
</script>
</body>
</html>
